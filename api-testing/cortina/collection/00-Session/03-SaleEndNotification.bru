meta {
  name: SaleEndNotification
  type: http
  seq: 3
}

post {
  url: {{base_url}}/Cortina/SaleEndNotification
  body: json
  auth: none
}

body:json {
  {
    "BasicInfo": {
      "TransactionId": "{{transaction_id}}",
      "SiteId": 1,
      "Amount": 5.00,
      "CurrencyCode": "USD"
    },
    "Status": {
      "Verdict": "Approved",
      "Code": 0
    }
  }
}

docs {
  Direction: Nayax → Integrator.
  Notifies the integrator that a sale has completed.
}
