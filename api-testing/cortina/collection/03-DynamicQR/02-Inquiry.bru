meta {
  name: DynamicQR Inquiry
  type: http
  seq: 2
}

post {
  url: {{base_url}}/Cortina/DynamicQR/Inquiry
  body: json
  auth: none
}

body:json {
  {
    "BasicInfo": {
      "TransactionId": "{{transaction_id}}",
      "SiteId": 12
    },
    "MachineInfo": {
      "Id": 869761713,
      "Name": "TestPayDynamicQR V2",
      "TerminalId": "987654321"
    }
  }
}

docs {
  Direction: Nayax → Integrator.
  Polls the integrator to check whether the consumer has scanned and paid the QR code.
  Returns the current payment status.
}
