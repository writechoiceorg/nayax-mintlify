meta {
  name: StaticQR Refund
  type: http
  seq: 6
}

post {
  url: {{base_url}}/Cortina/StaticQR/Refund
  body: json
  auth: none
}

body:json {
  {
    "BasicInfo": {
      "TransactionId": "{{transaction_id}}",
      "SiteId": 1,
      "Amount": 5.00,
      "RefundAmount": 5.00,
      "CurrencyCode": "USD"
    },
    "ActorInfo": {
      "Id": 2001537302,
      "MerchantId": "999999888885",
      "Name": "TestPayStaticQR V2 OP"
    },
    "MachineInfo": {
      "Id": 106791869,
      "Name": "Test Machine",
      "TerminalId": "8888888844"
    }
  }
}

docs {
  Direction: Nayax → Integrator.
  Refunds a settled static QR payment. Credits funds back to the consumer's payment source.
  RefundAmount may be partial (less than or equal to the original Amount).
}
