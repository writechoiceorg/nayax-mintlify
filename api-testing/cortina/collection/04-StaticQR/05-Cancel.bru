meta {
  name: StaticQR Cancel
  type: http
  seq: 5
}

post {
  url: {{base_url}}/Cortina/StaticQR/Cancel
  body: json
  auth: none
}

body:json {
  {
    "BasicInfo": {
      "TransactionId": "{{transaction_id}}",
      "SiteId": 1
    }
  }
}

docs {
  Direction: Nayax → Integrator.
  Cancels a static QR transaction that is in progress or pending.
}
