    },
    "DeviceInfo": {
      "HwSerial": "434324119376526",
      "FWVersion": "4.0.0.22"
    }
  }
}

docs {
  Direction: Nayax → Integrator.
  Nayax sends card + transaction data. Integrator calls payment processor and returns Approved/Declined.
}
