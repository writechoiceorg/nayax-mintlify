meta {
  name: CreditCard Authorization
  type: http
  seq: 1
}

post {
  url: {{base_url}}/Cortina/CreditCard/Authorization
  body: json
  auth: none
}

body:json {
  {
    "BasicInfo": {
      "Amount": 5.00,
      "CurrencyCode": "ILS",
      "SiteId": 1,
