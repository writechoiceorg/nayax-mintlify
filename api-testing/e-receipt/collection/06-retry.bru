meta {
  name: Retry Receipt
  type: http
  seq: 6
}

post {
  url: {{base_url}}/v1/Retry
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "paymentInfo": {
      "nayaxTransactionId": 0,
      "authCode": "",
      "settAmount": 0.00,
      "currencyCode": "USD",
      "siteId": 0,
      "paymentType": 0
    }
  }
}

docs {
  Direction: Integrator → Nayax
  Auth: None declared in spec.

  Re-generates or re-sends a receipt for a specific payment.
  Useful when the original /Generate call failed or the receipt was not delivered.

  Returns the same GenerateResponse as /Generate.

  Prerequisite: must have a valid nayaxTransactionId.

  Spec path: POST /v1/Retry
}
